# ============================================================================
# NW Monitor - Environment Example
# Copy to `.env` or set as real environment variables in your deployment system
# ============================================================================

# ----------------------------------------------------------------------------
# Core App Security
# ----------------------------------------------------------------------------
SECRET_KEY=change-this-to-a-random-production-secret
SECRET_ENCRYPTION_KEY=change-this-to-a-separate-random-production-secret

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG=false

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DB_TYPE=postgresql
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=network_monitor
PG_USER=netmonitor
PG_PASSWORD=change-this-db-password
PG_POOL_MIN=2
PG_POOL_MAX=30

# ----------------------------------------------------------------------------
# Monitoring Workers
# ----------------------------------------------------------------------------
MONITOR_MAX_WORKERS=12

# ----------------------------------------------------------------------------
# SMTP / Email Alerting
# These are stored in the app settings UI, but keep a copy in your secret store
# ----------------------------------------------------------------------------
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
EMAIL_RECIPIENT=

# ----------------------------------------------------------------------------
# Telegram Alerting
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----------------------------------------------------------------------------
# Built-in Webhook Alerting
# ----------------------------------------------------------------------------
WEBHOOK_URL=
WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# LDAP / Active Directory
# ----------------------------------------------------------------------------
LDAP_ENABLED=false
LDAP_SERVER=
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_BASE_DN=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_FILTER=(sAMAccountName={username})
LDAP_AUTO_CREATE=true
LDAP_DEFAULT_ROLE=viewer

# ----------------------------------------------------------------------------
# SSO / OIDC
# ----------------------------------------------------------------------------
SSO_ENABLED=false
SSO_PROVIDER_NAME=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_DISCOVERY_URL=
SSO_AUTHORIZE_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=
SSO_SCOPES=openid email profile
SSO_AUTO_CREATE=true
SSO_DEFAULT_ROLE=viewer

# ----------------------------------------------------------------------------
# Operational Notes
# ----------------------------------------------------------------------------
# 1. SECRET_KEY and SECRET_ENCRYPTION_KEY should not use the same final values.
# 2. SECRET_ENCRYPTION_KEY rotation requires planning because encrypted plugin
#    secrets depend on it.
# 3. Plugin integration secrets are stored in the database, encrypted at save time.
